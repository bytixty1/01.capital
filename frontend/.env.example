# Copy to .env.local and fill in real values. Never commit .env.local to git.

# FastAPI base URL used by the Next.js server (the /api/backend proxy and,
# later, RSC reads). The browser never calls the backend directly anymore.
BACKEND_URL=http://localhost:8000

# Legacy fallback for BACKEND_URL — kept so existing .env.local files keep
# working. No longer read by client code.
NEXT_PUBLIC_API_URL=http://localhost:8000
