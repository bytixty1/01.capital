# Copy these into Railway environment variables — never commit real values

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

API_PREFIX=/api
# Set this to your Vercel URL after deploying the frontend
CORS_ORIGINS=https://your-app.vercel.app

# Supabase Postgres — use Session Mode pooler URL from Supabase dashboard
DATABASE_URL=postgresql+asyncpg://postgres:[DB_PASSWORD]@db.tnbaaspuqexzhupuxnqa.supabase.co:5432/postgres?ssl=require

SUPABASE_URL=https://tnbaaspuqexzhupuxnqa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-strong-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
