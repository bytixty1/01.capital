# Copy this to .env and adjust for local development.
# Never commit a real .env — it's gitignored.

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://01capital:01capital@localhost:5432/01capital

# Generate a real one for any non-dev environment:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-every-environment
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Field-level encryption for PII (national IDs, MFA secrets) — 32-byte hex = 64 chars
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. The dev default is never safe for real data.
FIELD_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2
