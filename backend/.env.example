# Copy this to .env and adjust for local development.
# Never commit a real .env — it's gitignored.

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://01capital:01capital@localhost:5432/01capital

# Generate a real one for any non-dev environment:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-every-environment
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
