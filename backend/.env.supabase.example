# Supabase credentials — copy this file to .env.supabase and fill in real values.
# Never commit .env.supabase to git.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# DATABASE_URL=postgresql+asyncpg://postgres:[DB_PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres
